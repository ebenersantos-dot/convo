# ============================================================
# CONVO — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores.
# O .env NUNCA vai para o Git (já está no .gitignore).
# ============================================================

# Porta do servidor (Hostinger geralmente define via painel)
PORT=3000

# --- E-mail (Gmail) -----------------------------------------
# Conta que ENVIA as notificações
EMAIL_USER=letusconvo@gmail.com

# Senha de app do Gmail (16 caracteres, sem espaços).
# Gerar em: conta Google → Segurança → Verificação em duas
# etapas → Senhas de app. NÃO é a senha normal da conta.
EMAIL_PASS=sqhgjclzohbdccmj

# Conta que RECEBE as notificações
EMAIL_TO=letusconvo@gmail.com

# --- Opcional ------------------------------------------------
# Caminho do arquivo SQLite (padrão: backend/data/convo.db)
# DB_PATH=

# Origens extras permitidas para CORS, separadas por vírgula
# ALLOWED_ORIGINS=https://letusconvo.com,https://www.letusconvo.com
